<Window x:Class="ChallengeLab.App.Controls.Hud.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hud="clr-namespace:ChallengeLab.App.Controls.Hud"
        Title="Challenge Lab Approach HUD"
        Width="1280"
        Height="720"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True">
  <Grid Background="Transparent">
    <hud:HudVisual x:Name="Visual" IsHitTestVisible="False" />

    <Border x:Name="SizeControl"
            Width="176"
            Margin="24"
            Padding="10,7"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="#50101820"
            CornerRadius="8">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Opacity" Value="0.42" />
          <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Opacity" Value="0.9" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Margin="0,0,9,0"
                   VerticalAlignment="Center"
                   FontSize="9"
                   Foreground="#A8B6C7"
                   Text="HUD SIZE" />
        <Slider x:Name="SizeSlider"
                Grid.Column="1"
                Minimum="0.55"
                Maximum="1.25"
                SmallChange="0.05"
                LargeChange="0.1"
                Value="0.78"
                ValueChanged="OnSizeChanged" />

        <TextBlock Grid.Row="1"
                   Margin="0,6,9,0"
                   VerticalAlignment="Center"
                   FontSize="9"
                   Foreground="#A8B6C7"
                   Text="OPACITY" />
        <Slider x:Name="OpacitySlider"
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,6,0,0"
                Minimum="0.2"
                Maximum="1"
                SmallChange="0.05"
                LargeChange="0.1"
                Value="0.95"
                ValueChanged="OnOpacityChanged" />

        <TextBlock Grid.Row="2"
                   Margin="0,6,9,0"
                   VerticalAlignment="Center"
                   FontSize="9"
                   Foreground="#A8B6C7"
                   Text="FONT" />
        <Slider x:Name="FontScaleSlider"
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,6,0,0"
                Minimum="0.75"
                Maximum="1.35"
                SmallChange="0.05"
                LargeChange="0.1"
                Value="1.1"
                ValueChanged="OnFontScaleChanged" />
      </Grid>
    </Border>
  </Grid>
</Window>
