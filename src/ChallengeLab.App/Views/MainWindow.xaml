<Window x:Class="ChallengeLab.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ChallengeLab.App.Controls"
        Title="{Binding WindowTitle}"
        Height="820" Width="1180"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ResultTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Margin="18,0,18,0" Padding="4" CornerRadius="10"
                                    Background="#FF0B1020" BorderBrush="#2FFFFFFF" BorderThickness="1">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ResultTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#FF8B9BB8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="ResultTabBorder" Padding="{TemplateBinding Padding}" Margin="0,0,4,0"
                                CornerRadius="7" Background="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ResultTabBorder" Property="Background" Value="#332DE2E6"/>
                                <Setter Property="Foreground" Value="#FF2DE2E6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResultTabBorder" Property="Background" Value="#18FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VisualMetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#CC121D32"/>
            <Setter Property="BorderBrush" Value="#334A90A4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="11"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,20" Background="{StaticResource BrushBgPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CHALLENGE LAB" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource BrushAccentCyan}"/>
                    <TextBlock Text="Hardcore Landings &amp; Disasters" FontSize="26" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock Text="Configurable scoring · Separate from stock FS challenges"
                               Foreground="{StaticResource BrushTextMuted}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="20" Padding="12,6" Margin="0,0,12,0"
                            Background="#22000000" BorderBrush="{StaticResource BrushBorderSubtle}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource BrushAccentRed}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource BrushAccentGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Button Content="Connect" Style="{StaticResource GhostButton}" Command="{Binding ConnectCommand}" Padding="14,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <TabControl Grid.Row="1" Margin="24,12,24,8" SelectedIndex="{Binding SelectedTab}">
            <TabItem Header="CAREER">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.08*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="0.92*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="CLASSIFIED PROMOTION FLIGHTS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource BrushAccentAmber}"/>
                            <TextBlock Text="Earn the next stripe." FontSize="28" FontWeight="SemiBold"
                                       Margin="0,5,0,0"/>
                            <TextBlock Margin="0,5,0,16" TextWrapping="Wrap" LineHeight="20"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Text="Accept an undisclosed assignment, land it at 80% or better, and reveal the next future challenge. Career is optional — the regular Challenges tab stays open."/>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                                    Visibility="{Binding IsCareerAvailable, Converter={StaticResource BoolToVisInvert}}">
                                <StackPanel>
                                    <TextBlock Text="CAREER UNAVAILABLE" FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource BrushAccentRed}"/>
                                    <TextBlock Text="{Binding CareerConfigurationStatus, Mode=OneWay}" Margin="0,8,0,0"
                                               TextWrapping="Wrap" Foreground="{StaticResource BrushTextPrimary}"/>
                                    <TextBlock Text="Normal Challenges and Free Flight are still available."
                                               Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                                    Visibility="{Binding IsCareerAvailable, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="CURRENT RANK" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding CareerCurrentRankTitle, Mode=OneWay}"
                                                       FontSize="24" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#222DE2E6" CornerRadius="8" Padding="10,6"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CareerProgressText, Mode=OneWay}" FontSize="11"
                                                       FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}"/>
                                        </Border>
                                    </Grid>
                                    <ProgressBar Margin="0,14,0,0" Height="10" Maximum="100"
                                                 Value="{Binding CareerProgressPercent, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,12" Padding="20" CornerRadius="14"
                                    Background="#332DE2E6" BorderBrush="{StaticResource BrushAccentCyan}" BorderThickness="1"
                                    Visibility="{Binding CareerIsComplete, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="CAREER COMPLETE" FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource BrushAccentCyan}"/>
                                    <TextBlock Text="Command Captain" FontSize="30" FontWeight="Bold" Margin="0,5,0,0"/>
                                    <TextBlock Text="Five classified promotion flights passed. Every prototype reward is revealed."
                                               TextWrapping="Wrap" Margin="0,8,0,0" LineHeight="20"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                                    Visibility="{Binding CareerNeedsAssignment, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="NEXT ASSIGNMENT" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushAccentAmber}"/>
                                    <TextBlock Text="CLASSIFIED" FontSize="32" FontWeight="Bold" Margin="0,4,0,0"/>
                                    <Border Background="#22000000" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="AIRCRAFT · A330 REQUIRED" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding CareerPassRequirement, Mode=OneWay}"
                                                       FontWeight="SemiBold" Margin="0,5,0,0"/>
                                            <TextBlock Text="Airport, runway, weather, and mission brief reveal only after acceptance."
                                                       TextWrapping="Wrap" Margin="0,7,0,0"
                                                       Foreground="{StaticResource BrushTextMuted}"/>
                                        </StackPanel>
                                    </Border>
                                    <Button Content="ACCEPT CLASSIFIED ASSIGNMENT" Style="{StaticResource AmberButton}"
                                            Command="{Binding AcceptCareerAssignmentCommand}" Margin="0,16,0,0"/>
                                    <TextBlock Text="No reroll · unlimited retries · assignment persists after restart"
                                               Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                                    Visibility="{Binding CareerHasAssignment, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ASSIGNMENT REVEALED" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource BrushAccentCyan}"/>
                                        <Border Grid.Column="1" Background="#33FFB020" CornerRadius="6" Padding="8,4">
                                            <TextBlock Text="LOCKED IN" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource BrushAccentAmber}"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding CareerAssignmentTitle, Mode=OneWay}" FontSize="26"
                                               FontWeight="SemiBold" Margin="0,7,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding CareerAssignmentSubtitle, Mode=OneWay}"
                                               Foreground="{StaticResource BrushAccentCyan}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding CareerAssignmentAirportRunway, Mode=OneWay}"
                                               FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,12,0,0"/>
                                    <TextBlock Text="{Binding CareerAssignmentDescription, Mode=OneWay}"
                                               TextWrapping="Wrap" LineHeight="20" Margin="0,10,0,0"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <Border Background="#22000000" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="WEATHER" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding CareerAssignmentWeather, Mode=OneWay}"
                                                       FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding CareerAssignmentAcceptedAt, Mode=OneWay}" Margin="0,9,0,0"
                                               FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <Grid Margin="0,12,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding LoadStatus}" FontSize="12" Margin="0,0,0,6"
                                                   Foreground="{StaticResource BrushAccentCyan}"/>
                                        <ProgressBar Grid.Row="1" Maximum="100"
                                                     Value="{Binding LoadProgress, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"/>
                                    </Grid>
                                    <Button Content="START / RETRY ASSIGNMENT" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding StartCareerAssignmentCommand}" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}"
                                    Visibility="{Binding IsCareerAvailable, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="LAST CAREER RESULT" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding CareerLastOutcomeText, Mode=OneWay}" FontSize="15"
                                               FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0"
                                               Foreground="{StaticResource BrushAccentAmber}"/>
                                    <TextBlock Text="{Binding CareerAttemptCountText, Mode=OneWay}" FontSize="11"
                                               Margin="0,5,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="FUTURE CHALLENGE REWARDS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="One reveal per promotion" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding CareerRewards}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="13" Margin="0,0,0,10"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22000000"/>
                                                        <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnlocked}" Value="True">
                                                                <Setter Property="Background" Value="#222DE2E6"/>
                                                                <Setter Property="BorderBrush" Value="#662DE2E6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding StageLabel}" FontSize="9" FontWeight="Bold"
                                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" FontSize="9"
                                                                   FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding DisplayTitle}" FontSize="17" FontWeight="SemiBold"
                                                               Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding DisplaySubtitle}" FontSize="11" Margin="0,3,0,0"
                                                               Foreground="{StaticResource BrushAccentAmber}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="11" Margin="0,7,0,0"
                                                               Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="CHALLENGES">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock DockPanel.Dock="Top" Text="SELECT A CHALLENGE" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,10"/>
                        <ListView ItemsSource="{Binding Challenges}" SelectedItem="{Binding SelectedChallenge}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ModeTitle}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{StaticResource BrushAccentAmber}"/>
                                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,4" VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#33FFB020"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Available}" Value="True">
                                                                <Setter Property="Background" Value="#332DE2E6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource BrushAccentAmber}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Available}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource BrushAccentCyan}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <TextBlock Grid.Row="1" Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource BrushTextMuted}" Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Description}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource BrushTextMuted}" Margin="0,8,0,0" Opacity="0.9"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>

                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="MISSION BRIEF" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="{Binding SelectedChallenge.Title}" FontSize="22" FontWeight="SemiBold"
                                           Margin="0,8,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedChallenge.Subtitle}"
                                           Foreground="{StaticResource BrushAccentCyan}" Margin="0,4,0,12"/>
                                <TextBlock Text="{Binding SelectedChallenge.Description}" TextWrapping="Wrap"
                                           LineHeight="22" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="{Binding SelectedChallenge.ComingSoonNote}" TextWrapping="Wrap"
                                           Margin="0,12,0,0" Foreground="{StaticResource BrushAccentAmber}"
                                           Visibility="{Binding SelectedChallenge.Available, Converter={StaticResource BoolToVisInvert}}"/>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
                                <Border Background="#553A1010" BorderBrush="#FFFF6B6B" BorderThickness="1"
                                        CornerRadius="8" Padding="10" Margin="0,0,0,12"
                                        Visibility="{Binding HasValidScoringConfiguration, Converter={StaticResource BoolToVisInvert}}">
                                    <StackPanel>
                                        <TextBlock Text="SCORING CONFIGURATION ERROR" FontWeight="Bold"
                                                   Foreground="#FFFF8A8A"/>
                                        <TextBlock Text="{Binding ConfigurationStatus, Mode=OneWay}" TextWrapping="Wrap"
                                                   Margin="0,5,0,0" Foreground="#FFFFFFFF"/>
                                        <TextBlock Text="Correct the evaluation key, then restart Challenge Lab."
                                                   Margin="0,5,0,0" Foreground="#FFFFC0C0"/>
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0,0,0,8" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding LoadStatus}" FontSize="12" Margin="0,0,0,6"
                                               Foreground="{StaticResource BrushAccentCyan}"/>
                                    <ProgressBar Grid.Row="1" Maximum="100"
                                                 Value="{Binding LoadProgress, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"/>
                                </Grid>

                                <Button Content="START CHALLENGE" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding StartChallengeCommand}"
                                        Visibility="{Binding SelectedChallenge.Available, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="RESTART CURRENT" Style="{StaticResource GhostButton}"
                                        Command="{Binding RestartCommand}" Margin="0,10,0,0"/>
                            </StackPanel>

                            <Border/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="HIGHSCORES">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.72*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1.35*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardBorder}" Padding="8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="SELECT A LANDING"
                                       FontSize="11" FontWeight="Bold" Foreground="{StaticResource BrushTextMuted}"
                                       Margin="8,4,8,10"/>
                            <DataGrid x:Name="HighscoresGrid"
                                      ItemsSource="{Binding Highscores}"
                                      SelectedItem="{Binding SelectedHighscore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                                      Background="#FF0B1020" Foreground="#FFF2F6FF"
                                      RowBackground="#FF121A2E" AlternatingRowBackground="#FF1A2540"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#22FFFFFF"
                                      BorderThickness="0" SelectionChanged="HighscoresGrid_OnSelectionChanged">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FF1A2540"/>
                                        <Setter Property="Foreground" Value="#FFC5D0E6"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#FFF2F6FF"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="7,6"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#442DE2E6"/>
                                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date (UTC)" Binding="{Binding Utc, StringFormat=yyyy-MM-dd HH:mm}" Width="126"/>
                                    <DataGridTextColumn Header="Challenge" Binding="{Binding ChallengeTitle}" Width="*"/>
                                    <DataGridTextColumn Header="Score" Binding="{Binding ScorePercent, StringFormat={}{0:0.0}%}" Width="66"/>
                                    <DataGridTextColumn Header="VS (fpm)" Binding="{Binding VerticalSpeedDisplay}" Width="72"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorder}"
                            Visibility="{Binding LandingReport, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.85">
                            <TextBlock Text="LANDING REPORT" FontSize="14" FontWeight="Bold"
                                       Foreground="#FFF2F6FF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a highscore to inspect its score development,&#x0a;penalties and complete metric breakdown."
                                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,12,0,0"
                                       Foreground="#FFC5D0E6" MaxWidth="360" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#FF121A2E" BorderBrush="#33FFFFFF" BorderThickness="1"
                            CornerRadius="14" Padding="0"
                            Visibility="{Binding LandingReport, Converter={StaticResource NullToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Padding="18,16,18,12" BorderBrush="#22FFFFFF" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="LANDING RESULT" FontSize="10" FontWeight="Bold"
                                                   Foreground="#FF2DE2E6"/>
                                        <TextBlock Text="{Binding LandingReport.Title, Mode=OneWay}" FontSize="21"
                                                   FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding LandingReport.Subtitle, Mode=OneWay}" FontSize="11"
                                                   Foreground="#FF8B9BB8" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding SelectedHighscore.CareerDisplay, Mode=OneWay}"
                                                   Foreground="#FFFFB020" Margin="0,3,0,0" FontSize="10" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                        <TextBlock Text="{Binding LandingReport.ScorePercent, Mode=OneWay, StringFormat={}{0:0.0}%}"
                                                   FontSize="30" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                                        <TextBlock Text="{Binding LandingReport.Grade, Mode=OneWay}" FontSize="30" FontWeight="Bold"
                                                   Margin="10,0,0,0" Foreground="#FFFFB020"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Close" Style="{StaticResource GhostButton}"
                                            Padding="10,4" VerticalAlignment="Center"
                                            Command="{Binding ClearHighscoreSelectionCommand}"/>
                                </Grid>
                            </Border>

                            <TabControl Grid.Row="1" Style="{StaticResource ResultTabControlStyle}"
                                        SelectedIndex="{Binding SelectedResultTab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Margin="0,10,0,0">
                                <TabItem Header="SUMMARY" Style="{StaticResource ResultTabItemStyle}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                  Padding="18,14,18,18">
                                        <StackPanel x:Name="SummaryHost"/>
                                    </ScrollViewer>
                                </TabItem>
                                <TabItem Header="LANDING VISUAL" Style="{StaticResource ResultTabItemStyle}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                  Padding="18,14,18,18">
                                        <Grid>
                                            <StackPanel Visibility="{Binding LandingReport.HasVisualization, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.RunwayTitle, Mode=OneWay}"
                                                                   FontSize="16" FontWeight="Bold" Foreground="#FFF4F7FF"/>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.RunwayDetail, Mode=OneWay}"
                                                                   FontSize="10" Foreground="#FF8B9BB8" Margin="0,3,0,0"
                                                                   FontFamily="{StaticResource MonoFont}"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" CornerRadius="12" Padding="10,5"
                                                            Background="#222DE2E6" BorderBrush="#552DE2E6" BorderThickness="1">
                                                        <TextBlock Text="EXACT TOUCHDOWN PLOT" FontSize="9" FontWeight="Bold"
                                                                   Foreground="#FF2DE2E6"/>
                                                    </Border>
                                                </Grid>

                                                <Border Margin="0,10,0,0" CornerRadius="14" Background="#FF09131E"
                                                        BorderBrush="#334A90A4" BorderThickness="1" Padding="5">
                                                    <controls:PrecisionRunwayView Height="292"
                                                        Data="{Binding LandingReport.Visualization.Data, Mode=OneWay}"
                                                        AutomationProperties.Name="Exact runway-relative touchdown position"/>
                                                </Border>

                                                <Border Margin="0,10,0,0" Padding="14,11" CornerRadius="11"
                                                        Background="#CC10243A" BorderBrush="#552DE2E6" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.PositionHeadline, Mode=OneWay}"
                                                                   FontSize="15" FontWeight="Bold" Foreground="#FFFFFFFF"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding LandingReport.Visualization.PositionDetail, Mode=OneWay}"
                                                                   FontSize="10" Foreground="#FFB8F0F2" VerticalAlignment="Center"
                                                                   Margin="12,0,0,0" FontFamily="{StaticResource MonoFont}"/>
                                                    </Grid>
                                                </Border>

                                                <Border Margin="0,10,0,0" Padding="14,11" CornerRadius="11"
                                                        Background="#B3182238" BorderBrush="#334A90A4" BorderThickness="1"
                                                        Visibility="{Binding LandingReport.Visualization.HasRunwayAlignment, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.AlignmentHeadline, Mode=OneWay}"
                                                                   FontSize="9" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.AlignmentDetail, Mode=OneWay}"
                                                                   FontSize="12" FontWeight="SemiBold" Foreground="#FFF4F7FF"
                                                                   Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.AlignmentSource, Mode=OneWay}"
                                                                   FontSize="9" Foreground="#FF8B9BB8" Margin="0,4,0,0"
                                                                   TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                    </StackPanel>
                                                </Border>

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.02*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="0.98*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <controls:TouchdownAttitudeView Grid.Column="0" Height="222"
                                                        Data="{Binding LandingReport.Visualization.Data, Mode=OneWay}"
                                                        AutomationProperties.Name="Touchdown bank and pitch attitude"/>

                                                    <Grid Grid.Column="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="8"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource VisualMetricCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.VerticalSpeed.Label, Mode=OneWay}" FontSize="8" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.VerticalSpeed.Value, Mode=OneWay}" FontSize="25" FontWeight="Bold" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.VerticalSpeed.UnitDetail, Mode=OneWay}" FontSize="9" Foreground="#FFFFC766"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.VerticalSpeed.Result, Mode=OneWay}" FontSize="8" Foreground="#FFFFB020" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource VisualMetricCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.PeakG.Label, Mode=OneWay}" FontSize="8" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.PeakG.Value, Mode=OneWay}" FontSize="25" FontWeight="Bold" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.PeakG.UnitDetail, Mode=OneWay}" FontSize="9" Foreground="#FFFFC766"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.PeakG.Result, Mode=OneWay}" FontSize="8" Foreground="#FFFFB020" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource VisualMetricCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Bank.Label, Mode=OneWay}" FontSize="8" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Bank.Value, Mode=OneWay}" FontSize="25" FontWeight="Bold" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Bank.UnitDetail, Mode=OneWay}" FontSize="9" Foreground="#FFB8F0F2"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Bank.Result, Mode=OneWay}" FontSize="8" Foreground="#FF2DE2E6" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource VisualMetricCardStyle}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Airspeed.Label, Mode=OneWay}" FontSize="8" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Airspeed.Value, Mode=OneWay}" FontSize="25" FontWeight="Bold" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Airspeed.UnitDetail, Mode=OneWay}" FontSize="8" Foreground="#FFB8F0F2" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding LandingReport.Visualization.Airspeed.Result, Mode=OneWay}" FontSize="8" Foreground="#FF2DE2E6" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Grid>

                                                <Border Margin="0,12,0,0" Padding="15" CornerRadius="13"
                                                        Background="#B3182238" BorderBrush="#334A90A4" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="LANDING COACH" FontSize="9" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.VerdictHeadline, Mode=OneWay}"
                                                                   FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding LandingReport.Visualization.VerdictSummary, Mode=OneWay}"
                                                                   TextWrapping="Wrap" FontSize="12" LineHeight="18" Foreground="#FFDCE6F8" Margin="0,6,0,0"/>
                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Padding="12" CornerRadius="10" Background="#3324B47E" BorderBrush="#5562E6A7" BorderThickness="1">
                                                                <StackPanel>
                                                                    <TextBlock Text="WHAT WENT WELL" FontSize="8" FontWeight="Bold" Foreground="#FF62E6A7"/>
                                                                    <TextBlock Text="{Binding LandingReport.Visualization.StrengthTitle, Mode=OneWay}" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding LandingReport.Visualization.StrengthBody, Mode=OneWay}" FontSize="11" Foreground="#FFDCE6F8" Margin="0,5,0,0" TextWrapping="Wrap" LineHeight="16"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="2" Padding="12" CornerRadius="10" Background="#333A2810" BorderBrush="#66FFB020" BorderThickness="1">
                                                                <StackPanel>
                                                                    <TextBlock Text="IMPROVE NEXT" FontSize="8" FontWeight="Bold" Foreground="#FFFFB020"/>
                                                                    <TextBlock Text="{Binding LandingReport.Visualization.ImprovementTitle, Mode=OneWay}" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding LandingReport.Visualization.ImprovementBody, Mode=OneWay}" FontSize="11" Foreground="#FFFFE9C2" Margin="0,5,0,0" TextWrapping="Wrap" LineHeight="16"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <Border Padding="28" CornerRadius="14" Background="#AA0B1020"
                                                    BorderBrush="#334A90A4" BorderThickness="1"
                                                    Visibility="{Binding LandingReport.HasVisualization, Converter={StaticResource BoolToVisInvert}}">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="390">
                                                    <TextBlock Text="RUNWAY POSITION NOT RECORDED" FontSize="14" FontWeight="Bold"
                                                               Foreground="#FFFFB020" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding LandingReport.VisualizationUnavailableText, Mode=OneWay}"
                                                               TextWrapping="Wrap" TextAlignment="Center" Foreground="#FFC5D0E6"
                                                               Margin="0,10,0,0" LineHeight="19"/>
                                                    <TextBlock Text="The detailed score report is still fully available in the next tab."
                                                               TextWrapping="Wrap" TextAlignment="Center" Foreground="#FF8B9BB8"
                                                               Margin="0,8,0,0" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="DETAILED REPORT" Style="{StaticResource ResultTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" Padding="18">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4" LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding LandingReport.RunwayLengthDisplay, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FF8B9BB8" VerticalAlignment="Center"
                                               Margin="16,0,0,0"
                                               Visibility="{Binding LandingReport.HasRunwayLength, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="COMPLETE SCORE BREAKDOWN" FontSize="10" FontWeight="Bold"
                                               Foreground="#FF2DE2E6" VerticalAlignment="Center"/>
                                </DockPanel>

                                <Border x:Name="PhaseSummarySection" Margin="0,12,0,0" Padding="12"
                                        CornerRadius="10" Background="#331A2540" BorderBrush="#334A90A4" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="PHASE RESULTS" FontSize="10" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                                        <WrapPanel x:Name="PhaseSummaryHost" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,12,0,0" Padding="14,12" CornerRadius="12"
                                        Background="#441A2540" BorderBrush="#334A90A4" BorderThickness="1"
                                        Visibility="{Binding LandingReport.HasProjectedScoreHistory, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="210"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="PROJECTED SCORE DEVELOPMENT" FontSize="11" FontWeight="Bold"
                                                       Foreground="#FF2DE2E6"/>
                                            <TextBlock Grid.Column="1" Text="RED = POINT LOSS  ·  TIME →" FontSize="9"
                                                       Foreground="#FF8B9BB8"/>
                                        </Grid>
                                        <controls:LandingScoreGraph Grid.Row="1" Margin="0,8,0,0"
                                                                    Points="{Binding LandingReport.ProjectedScoreHistory, Mode=OneWay}"/>
                                    </Grid>
                                </Border>
                                <Border Margin="0,12,0,0" Padding="16" CornerRadius="12"
                                        Background="#221A2540" BorderBrush="#334A90A4" BorderThickness="1"
                                        Visibility="{Binding LandingReport.HasProjectedScoreHistory, Converter={StaticResource BoolToVisInvert}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="PROJECTED SCORE DEVELOPMENT" FontSize="10" FontWeight="Bold"
                                                   Foreground="#FF8B9BB8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LandingReport.ProjectedScoreHistoryUnavailableText}" Margin="0,6,0,0"
                                                   Foreground="#FFC5D0E6" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="PenaltySection" Margin="0,12,0,0" Padding="14" CornerRadius="12"
                                        Background="#553A1018" BorderBrush="#FFFF4D6A" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="PENALTIES" FontSize="11" FontWeight="Bold" Foreground="#FFFF7A8E"/>
                                        <TextBlock Text="{Binding LandingReport.PenaltySummary}" Margin="0,4,0,0"
                                                   FontSize="12" Foreground="#FFFFC2CC" TextWrapping="Wrap"/>
                                        <StackPanel x:Name="PenaltiesHost" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#FF3A3010" CornerRadius="12" Padding="14"
                                            BorderBrush="#FFFFB020" BorderThickness="2">
                                        <StackPanel>
                                            <TextBlock Text="TOUCHDOWN IMPACT" FontSize="10" FontWeight="Bold" Foreground="#FFFFB020"/>
                                            <TextBlock Text="{Binding LandingReport.VerticalSpeedHeadline}" FontSize="16"
                                                       FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#FFFFFFFF"/>
                                            <TextBlock Text="{Binding LandingReport.VerticalSpeedScoreLabel}" FontSize="12"
                                                       Margin="0,4,0,0" Foreground="#FFFFE0A0"/>
                                            <ProgressBar Height="12" Minimum="0" Maximum="100" Margin="0,10,0,0"
                                                         Value="{Binding LandingReport.VerticalSpeedScorePercent, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"/>
                                            <TextBlock Text="{Binding LandingReport.VerticalSpeedExplanation}" TextWrapping="Wrap"
                                                       FontSize="12" Foreground="#FFFFFFFF" Margin="0,10,0,0" LineHeight="17"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#FF102A3A" CornerRadius="12" Padding="14"
                                            BorderBrush="#FF2DE2E6" BorderThickness="2">
                                        <StackPanel>
                                            <TextBlock Text="LANDING SPEED" FontSize="10" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                                            <TextBlock Text="{Binding LandingReport.AirspeedHeadline}" FontSize="16"
                                                       FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#FFFFFFFF"/>
                                            <TextBlock Text="{Binding LandingReport.AirspeedDisplay}" FontSize="12"
                                                       Margin="0,4,0,0" FontFamily="{StaticResource MonoFont}"
                                                       Foreground="#FFB8F0F2" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding LandingReport.AirspeedScoreLabel}" FontSize="12"
                                                       Margin="0,4,0,0" Foreground="#FFA0E0FF"/>
                                            <ProgressBar Height="12" Minimum="0" Maximum="100" Margin="0,10,0,0"
                                                         Value="{Binding LandingReport.AirspeedScorePercent, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"/>
                                            <TextBlock Text="{Binding LandingReport.AirspeedExplanation}" TextWrapping="Wrap"
                                                       FontSize="12" Foreground="#FFFFFFFF" Margin="0,10,0,0" LineHeight="17"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="DETAILED RESULTS" Margin="0,18,0,8" FontSize="11" FontWeight="Bold"
                                           Foreground="#FF8B9BB8"/>
                                <StackPanel x:Name="MetricsHost"/>

                                <TextBlock x:Name="ReportStatusText" Visibility="Collapsed" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ReportBodyBlock" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="SESSION">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="LIVE TELEMETRY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding LiveStats}" FontFamily="{StaticResource MonoFont}" FontSize="14" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding SpeedTargetInfo}" FontFamily="{StaticResource MonoFont}" FontSize="13"
                                       Margin="0,8,0,0" Foreground="{StaticResource BrushAccentCyan}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,10,0,0">
                                <Run Text="Phase: " Foreground="{StaticResource BrushTextMuted}"/>
                                <Run Text="{Binding PhaseLabel, Mode=OneWay}" Foreground="{StaticResource BrushAccentCyan}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Text="{Binding HudTip}" TextWrapping="Wrap" Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushAccentAmber}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12"
                            Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="LAST RESULT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource BrushTextMuted}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding LastScore.ScoreDisplay, Mode=OneWay}" FontSize="42" FontWeight="Bold"
                                           Foreground="{StaticResource BrushAccentCyan}"/>
                                <TextBlock Text="{Binding LastScore.Grade}" FontSize="42" FontWeight="Bold" Margin="16,0,0,0"
                                           Foreground="{StaticResource BrushAccentAmber}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding LastScore.Summary}" TextWrapping="Wrap" Margin="0,6,0,0"
                                       FontFamily="{StaticResource MonoFont}" FontSize="13"
                                       Foreground="{StaticResource BrushTextPrimary}" xml:space="preserve"/>
                            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding CriterionResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" CornerRadius="10"
                                                    Background="#121A2540" BorderBrush="#22FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Margin="8,0"
                                                                Background="#22000000">
                                                            <TextBlock Text="{Binding Verdict}" FontSize="10" FontWeight="Bold"
                                                                       Foreground="{StaticResource BrushAccentAmber}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding ScoreDisplay, Mode=OneWay}"
                                                                   FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}"/>
                                                    </Grid>
                                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource MonoFont}" FontSize="12">
                                                        <Run Text="Value: " Foreground="{StaticResource BrushTextMuted}"/>
                                                        <Run Text="{Binding RawDisplay, Mode=OneWay}"/>
                                                        <Run Text="  ·  " Foreground="{StaticResource BrushTextMuted}"/>
                                                        <Run Text="{Binding InfluenceDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <ProgressBar Height="8" Minimum="0" Maximum="100"
                                                                 Value="{Binding BarValue, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"
                                                                 Margin="0,8,0,0"
                                                                 Visibility="{Binding IsScored, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="EXPLANATION" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource BrushAccentCyan}" Margin="0,10,0,4"/>
                                                    <TextBlock Text="{Binding Note}" TextWrapping="Wrap" FontSize="12"
                                                               LineHeight="18" Foreground="{StaticResource BrushTextPrimary}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="LOG" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding LogText}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="TESTING">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardBorder}" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="FLIGHT TAPES" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="Full-rate recordings saved when a landing settles."
                                           Margin="0,6,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource BrushTextPrimary}"/>
                                <TextBlock Text="{Binding FlightsFolderPath}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource BrushAccentCyan}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Refresh" Command="{Binding RefreshFlightTapesCommand}"
                                            Padding="12,6" Margin="0,0,8,0"/>
                                    <Button Content="Open folder" Command="{Binding OpenFlightsFolderCommand}"
                                            Padding="12,6" Margin="0,0,8,0"/>
                                    <Button Content="Browse…" Command="{Binding BrowseFlightTapeCommand}"
                                            Padding="12,6"/>
                                </StackPanel>
                                <Button Content="Evaluate from file" Command="{Binding EvaluateSelectedFlightTapeCommand}"
                                        Padding="14,8" Margin="0,10,0,0" HorizontalAlignment="Left"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding FlightTapes}"
                                     SelectedItem="{Binding SelectedFlightTape}"
                                     DisplayMemberPath="DisplayName"
                                     Background="#FF0B1020"
                                     Foreground="#FFF2F6FF"
                                     BorderBrush="#33FFFFFF"
                                     BorderThickness="1"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="#FFF2F6FF"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="Margin" Value="0,0,0,2"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#FF223054"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#332DE2E6"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#662DE2E6"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                                <Condition Property="IsMouseOver" Value="True"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="Bd" Property="Background" Value="#442DE2E6"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </MultiTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="OFFLINE EVALUATION" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="{Binding TestingStatus}" TextWrapping="Wrap" Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushAccentAmber}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                            Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding LastScore.ScoreDisplay, Mode=OneWay}" FontSize="36" FontWeight="Bold"
                                               Foreground="{StaticResource BrushAccentCyan}"/>
                                    <TextBlock Text="{Binding LastScore.Grade}" FontSize="36" FontWeight="Bold" Margin="14,0,0,0"
                                               Foreground="{StaticResource BrushAccentAmber}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding LastScore.Summary, Mode=OneWay}" TextWrapping="Wrap" Margin="0,8,0,0"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}"
                                           xml:space="preserve"/>
                                <TextBlock Text="{Binding ReportStatus}" TextWrapping="Wrap" Margin="0,10,0,0"
                                           FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CriterionResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" CornerRadius="10"
                                                    Background="#121A2540" BorderBrush="#22FFFFFF" BorderThickness="1">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Margin="8,0"
                                                                Background="#22000000">
                                                            <TextBlock Text="{Binding Verdict}" FontSize="10" FontWeight="Bold"
                                                                       Foreground="{StaticResource BrushAccentAmber}"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding ScoreDisplay, Mode=OneWay}"
                                                                   FontWeight="Bold" Foreground="{StaticResource BrushAccentCyan}"/>
                                                    </Grid>
                                                    <TextBlock Margin="0,6,0,0" FontFamily="{StaticResource MonoFont}" FontSize="12">
                                                        <Run Text="Value: " Foreground="{StaticResource BrushTextMuted}"/>
                                                        <Run Text="{Binding RawDisplay, Mode=OneWay}"/>
                                                        <Run Text="  ·  " Foreground="{StaticResource BrushTextMuted}"/>
                                                        <Run Text="{Binding InfluenceDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <ProgressBar Height="8" Minimum="0" Maximum="100"
                                                                 Value="{Binding BarValue, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"
                                                                 Margin="0,8,0,0"
                                                                 Visibility="{Binding IsScored, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="EXPLANATION" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource BrushAccentCyan}" Margin="0,10,0,4"/>
                                                    <TextBlock Text="{Binding Note}" TextWrapping="Wrap" FontSize="12"
                                                               LineHeight="18" Foreground="{StaticResource BrushTextPrimary}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="STORE">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 1/3 · Save -->
                    <Border Style="{StaticResource CardBorder}" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="SAVE FLIGHT STATE" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           Text="Stores position, attitude, exact speed vector, gear, flaps, spoilers, trim, parking brake, fuel, engines, lights, autopilot (modes + targets), time of day and ambient weather."/>
                                <TextBlock Text="{Binding SnapshotsFolderPath}" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource BrushAccentCyan}"/>

                                <TextBlock Text="NAME (OPTIONAL PREFIX)" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}" Margin="0,14,0,4"/>
                                <TextBox Text="{Binding SnapshotNameInput, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#FF0B1020" Foreground="#FFF2F6FF" CaretBrush="#FFF2F6FF"
                                         BorderBrush="#33FFFFFF" BorderThickness="1" Padding="8,6"/>

                                <Button Content="Save flight state" Command="{Binding SaveSnapshotCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="14,8" Margin="0,12,0,0" HorizontalAlignment="Left"/>

                                <TextBlock Margin="0,14,0,0" TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource BrushTextMuted}"
                                           Text="Not captured: addon FMS/routes. Autopilot is best-effort on complex addons; NAV needs a flight plan. Weather is an approximate fixed METAR. Load requires the same aircraft."/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- 1/3 · List + actions -->
                    <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="STORED FLIGHTS" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Text="{Binding StoreStatus}" TextWrapping="Wrap" Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushAccentAmber}"/>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="Load" Command="{Binding LoadSnapshotCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="12,6" Margin="0,0,8,8"/>
                                    <Button Content="Resume now" Command="{Binding ResumeNowCommand}"
                                            Style="{StaticResource AmberButton}"
                                            Padding="12,6" Margin="0,0,8,8"/>
                                    <Button Content="Rename" Command="{Binding RenameSnapshotCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="12,6" Margin="0,0,8,8"/>
                                    <Button Content="Delete" Command="{Binding DeleteSnapshotCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="12,6" Margin="0,0,8,8"/>
                                    <Button Content="Refresh" Command="{Binding RefreshSnapshotsCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="12,6" Margin="0,0,8,8"/>
                                    <Button Content="Open folder" Command="{Binding OpenSnapshotsFolderCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Padding="12,6" Margin="0,0,8,8"/>
                                </WrapPanel>
                                <StackPanel Margin="0,2,0,0">
                                    <CheckBox Content="Restore weather (approx.)"
                                              IsChecked="{Binding RestoreWeatherEnabled}"
                                              Foreground="{StaticResource BrushTextPrimary}"
                                              Margin="0,0,0,6"/>
                                    <CheckBox Content="Restore autopilot"
                                              IsChecked="{Binding RestoreAutopilotEnabled}"
                                              Foreground="{StaticResource BrushTextPrimary}"
                                              Margin="0,0,0,6"/>
                                    <CheckBox Content="Auto-resume after load"
                                              IsChecked="{Binding AutoResumeAfterRestore}"
                                              Foreground="{StaticResource BrushTextPrimary}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0"
                                        Visibility="{Binding IsRenamingSnapshot, Converter={StaticResource BoolToVis}}">
                                <TextBox Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                         MinWidth="120" Background="#FF0B1020" Foreground="#FFF2F6FF"
                                         CaretBrush="#FFF2F6FF" BorderBrush="#33FFFFFF" BorderThickness="1"
                                         Padding="8,6" VerticalAlignment="Center"/>
                                <Button Content="OK" Command="{Binding ConfirmRenameSnapshotCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="12,6" Margin="8,0,0,0"/>
                                <Button Content="Cancel" Command="{Binding CancelRenameSnapshotCommand}"
                                        Style="{StaticResource GhostButton}"
                                        Padding="12,6" Margin="8,0,0,0"/>
                            </StackPanel>

                            <ListBox ItemsSource="{Binding Snapshots}"
                                     SelectedItem="{Binding SelectedSnapshot}"
                                     DisplayMemberPath="DisplayName"
                                     Background="#FF0B1020"
                                     Foreground="#FFF2F6FF"
                                     BorderBrush="#33FFFFFF"
                                     BorderThickness="1"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Foreground" Value="#FFF2F6FF"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="Margin" Value="0,0,0,2"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#FF223054"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#332DE2E6"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#662DE2E6"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                                <Condition Property="IsMouseOver" Value="True"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="Bd" Property="Background" Value="#442DE2E6"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </MultiTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- 1/3 · Selected snapshot detail -->
                    <Border Grid.Column="4" Style="{StaticResource CardBorder}" Padding="12">
                        <Grid>
                            <TextBlock Text="Select a stored flight to inspect its saved state."
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding HasSelectedSnapshotDetail, Converter={StaticResource BoolToVisInvert}}"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Visibility="{Binding HasSelectedSnapshotDetail, Converter={StaticResource BoolToVis}}">
                                <StackPanel DataContext="{Binding SelectedSnapshotDetail}">
                                    <TextBlock Text="SAVED STATE" FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                               Foreground="{StaticResource BrushAccentCyan}" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Aircraft}" TextWrapping="Wrap" Margin="0,8,0,0"
                                               Foreground="{StaticResource BrushTextPrimary}"/>
                                    <TextBlock Text="{Binding Airport}" TextWrapping="Wrap" Margin="0,2,0,0"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <TextBlock Text="{Binding Situation}" FontWeight="Bold" Margin="0,4,0,0"
                                               Foreground="{StaticResource BrushAccentAmber}"/>

                                    <TextBlock Text="SPEED &amp; ALTITUDE" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMuted}" Margin="0,16,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Text="IAS" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding Ias}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="TAS" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding Tas}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Margin="0,0,8,8">
                                            <TextBlock Text="Ground speed" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding GroundSpeed}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Vertical speed" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding VerticalSpeed}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Margin="0,0,8,8">
                                            <TextBlock Text="Altitude" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding AltitudeMsl}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Height AGL" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding AltitudeAgl}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Margin="0,0,8,0">
                                            <TextBlock Text="Heading" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding Heading}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="1">
                                            <TextBlock Text="Pitch / bank" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock FontWeight="SemiBold" Foreground="#FFF2F6FF">
                                                <Run Text="{Binding Pitch, Mode=OneWay}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding Bank, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMuted}" Margin="0,16,0,6"/>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Gear" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding Gear}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Flaps" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding Flaps}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Spoilers" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding Spoilers}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Parking brake" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding ParkingBrake}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Throttles" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding Engines}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Fuel" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding Fuel}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <TextBlock Text="AUTOPILOT" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMuted}" Margin="0,16,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Text="AP master" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding AutopilotMaster}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Flight director" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding FlightDirector}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Margin="0,0,8,8">
                                            <TextBlock Text="Autothrust" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding Autothrust}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="A/T target" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding AutothrustTarget}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Margin="0,0,8,8">
                                            <TextBlock Text="Lateral / NAV mode" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding NavMode}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Heading mode" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding HeadingMode}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Margin="0,0,8,8">
                                            <TextBlock Text="Heading bug" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding HeadingBug}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Altitude mode" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding AltitudeMode}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="4" Margin="0,0,8,8">
                                            <TextBlock Text="Altitude set" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding AltitudeTarget}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Vertical mode" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding VerticalMode}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="5" Margin="0,0,8,8">
                                            <TextBlock Text="VS / FLC target" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding VerticalTarget}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,8">
                                            <TextBlock Text="Speed mode" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding SpeedMode}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="6" Margin="0,0,8,0">
                                            <TextBlock Text="Speed target" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding SpeedTarget}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="6" Grid.Column="1">
                                            <TextBlock Text="Yaw damper" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                            <TextBlock Text="{Binding YawDamper}" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="TIME &amp; WEATHER" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource BrushTextMuted}" Margin="0,16,0,6"/>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Zulu time" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding TimeZulu}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Weather" FontSize="10" Foreground="{StaticResource BrushTextMuted}"/>
                                        <TextBlock Text="{Binding Weather}" FontWeight="SemiBold" Foreground="#FFF2F6FF" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource BrushBgPanel}" Padding="20,10">
            <TextBlock Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                       Text="Tip: Accept a classified Career flight or use Challenges directly. Load the A330 in MSFS first; after landing, slow below 50 knots to score."/>
        </Border>
    </Grid>
</Window>
