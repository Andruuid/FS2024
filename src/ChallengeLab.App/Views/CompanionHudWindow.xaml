<Window x:Class="ChallengeLab.App.Views.CompanionHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Challenge Lab HUD"
        Width="440" Height="460"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <!-- Outer border is the visible chrome; drag works on empty space (not buttons). -->
    <Border x:Name="ChromeBorder" CornerRadius="16" BorderBrush="#552DE2E6" BorderThickness="1" Margin="8"
            MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
        <Border.Background>
            <SolidColorBrush x:Name="ChromeBackground" Color="#E0121A2E"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect x:Name="ChromeShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Drag handle area (title strip) -->
            <Grid x:Name="HeaderBar" MouseLeftButtonDown="Chrome_MouseLeftButtonDown"
                  Background="#01000000" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CHALLENGE LAB" FontSize="10" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                    <TextBlock Text="{Binding PhaseLabel}" FontSize="16" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#22FFFFFF" CornerRadius="7" Padding="2"
                        Margin="8,0,8,0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Normal" Command="{Binding NormalModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Setter Property="Padding" Value="9,5"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNormalMode}" Value="True">
                                            <Setter Property="Background" Value="#FF2DE2E6"/>
                                            <Setter Property="Foreground" Value="#FF0B1020"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Free" Command="{Binding FreeModeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Setter Property="Padding" Value="11,5"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFreeMode}" Value="True">
                                            <Setter Property="Background" Value="#FF2DE2E6"/>
                                            <Setter Property="Foreground" Value="#FF0B1020"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
                <Button x:Name="FlightMonitorButton" Grid.Column="2" Content="Monitor"
                        Command="{Binding ToggleSecondaryHudCommand}" Margin="0,0,7,0"
                        ToolTip="Show or hide live approach guidance and projected-score graph.">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="Padding" Value="9,5"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSecondaryHudVisible}" Value="True">
                                    <Setter Property="Background" Value="#FF2DE2E6"/>
                                    <Setter Property="Foreground" Value="#FF0B1020"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="3" Content="✕" Style="{StaticResource GhostButton}" Padding="10,4"
                        Click="CompactToggle_Click" VerticalAlignment="Top"
                        ToolTip="Collapse HUD to a small Show button"/>
            </Grid>

            <StackPanel x:Name="ContentBody" Grid.Row="1" Grid.RowSpan="2">
                <TextBlock Text="{Binding HudTip}" TextWrapping="Wrap" Margin="0,12,0,8"
                           Foreground="#FFFFB020" FontSize="13"/>

                <Border Margin="0,0,0,10" Background="#221A3A4A" CornerRadius="8" Padding="10,7"
                        BorderBrush="#442DE2E6" BorderThickness="1"
                        Visibility="{Binding IsFreeMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="FREE FLIGHT · AIRPORT / RUNWAY" FontSize="9" FontWeight="Bold"
                                   Foreground="#FF2DE2E6"/>
                        <TextBlock Text="{Binding FreeAirportStatus}" TextWrapping="Wrap" Margin="0,3,0,0"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                   Foreground="#FFE8F8FF"/>
                    </StackPanel>
                </Border>

                <!-- Live projected overall % -->
                <Border Margin="0,0,0,10" Background="#330A2A20" CornerRadius="10" Padding="12,10"
                        BorderBrush="#66FFB020" BorderThickness="1"
                        Visibility="{Binding PreviewActive, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding PreviewHeading}" FontSize="10" FontWeight="Bold"
                                   Foreground="#FFFFB020"
                                   ToolTip="Live projection while airborne (unmeasured metrics = 100%). Switches to FINAL SCORE after settle."/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding PreviewScoreDisplay}" FontSize="40" FontWeight="Bold"
                                       Foreground="#FF2DE2E6"/>
                            <TextBlock Text="{Binding PreviewGrade}" FontSize="40" FontWeight="Bold"
                                       Margin="12,0,0,0" Foreground="#FFFFB020"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PreviewCaption}" FontSize="11" Foreground="#FF8B9BB8"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                        <!-- Live "why score is low": too high / too fast / weaving / … -->
                        <TextBlock Text="{Binding PreviewIssues}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#FFFF6B6B" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding HasPreviewIssues, Converter={StaticResource BoolToVis}}"
                                   ToolTip="Live issues hurting the preview score (path, speed, config, measured metrics)."/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding LiveStats}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                           Foreground="#FF8B9BB8" TextWrapping="Wrap"/>

                <Border Margin="0,10,0,0" Background="#221A3A4A" CornerRadius="8" Padding="10,8"
                        BorderBrush="#442DE2E6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="INFO · PERFECT LANDING SPEED" FontSize="9" FontWeight="Bold"
                                   Foreground="#FF2DE2E6"/>
                        <TextBlock Text="{Binding SpeedTargetInfo}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   Foreground="#FFE8F8FF"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0" Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}"
                        Background="#22000000" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="LANDING SCORE" FontSize="10" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding LastScore.ScoreDisplay, Mode=OneWay}"
                                       FontSize="36" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                            <TextBlock Text="{Binding LastScore.Grade}" FontSize="36" FontWeight="Bold"
                                       Margin="12,0,0,0" Foreground="#FFFFB020"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                            <TextBlock Text="{Binding LastScore.Summary}" TextWrapping="Wrap" FontSize="12"
                                       FontFamily="Cascadia Mono, Consolas"
                                       Foreground="#FFE8EEF8" xml:space="preserve"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Spawn readiness: PREPARING (spinner) / READY before GO -->
            <Border x:Name="SpawnReadinessBar" Grid.Row="3" Margin="0,10,0,0" Padding="10,8"
                    CornerRadius="8" BorderThickness="1"
                    Visibility="{Binding ShowSpawnReadiness, Converter={StaticResource BoolToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#33FFB020"/>
                        <Setter Property="BorderBrush" Value="#88FFB020"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSpawnReady}" Value="True">
                                <Setter Property="Background" Value="#222DE2E6"/>
                                <Setter Property="BorderBrush" Value="#662DE2E6"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Spinning ring while preparing -->
                    <Grid Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"
                          Visibility="{Binding IsSpawnPreparing, Converter={StaticResource BoolToVis}}">
                        <Ellipse Width="18" Height="18" Stroke="#FFFFB020" StrokeThickness="2.5"
                                 StrokeDashArray="3.5 2.2" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="PrepSpinnerRotate" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0" To="360" Duration="0:0:0.9"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <!-- Checkmark when ready -->
                    <TextBlock Grid.Column="0" Text="✓" FontSize="16" FontWeight="Bold"
                               Foreground="#FF2DE2E6" VerticalAlignment="Center" Margin="0,0,10,0"
                               Visibility="{Binding IsSpawnReady, Converter={StaticResource BoolToVis}}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SpawnReadinessText}" FontSize="13" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FFFFB020"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSpawnReady}" Value="True">
                                            <Setter Property="Foreground" Value="#FF2DE2E6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding SpawnReadinessDetail}" FontSize="10"
                                   FontFamily="Cascadia Mono, Consolas" Foreground="#FFC5D0E6"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="FooterBar" Grid.Row="4" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="GoButton" Grid.Column="0" Content="GO" Style="{StaticResource AmberButton}"
                        Command="{Binding GoCommand}"
                        ToolTip="Resume flight (SET PAUSE OFF). Enabled only when spawn speed and config are ready."
                        FontWeight="Bold" FontSize="14" Padding="22,10" MinWidth="72"
                        HorizontalAlignment="Left"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CleanButton" Content="Clear" Style="{StaticResource GhostButton}"
                            Command="{Binding CleanMetricsCommand}"
                            ToolTip="Clear this attempt. In Free mode, also release the runway and detect again in place."
                            Padding="12,8" Margin="0,0,8,0"/>
                    <Button x:Name="RestartButton" Content="Restart" Style="{StaticResource GhostButton}"
                            Command="{Binding RestartCommand}"
                            Padding="12,8" Margin="0,0,8,0"/>
                    <Button x:Name="MenuButton" Content="Menu" Style="{StaticResource GhostButton}"
                            Command="{Binding OpenMenuCommand}"
                            ToolTip="Show or hide the main Challenge Lab window (HUD stays)."
                            Padding="12,8" Margin="0,0,8,0"/>
                    <Button x:Name="HideShowButton" Content="Hide" Style="{StaticResource GhostButton}"
                            Click="CompactToggle_Click" Padding="12,8"
                            ToolTip="Collapse HUD to a small Show chip (drag to move)."/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
