<Window x:Class="ChallengeLab.App.Views.CompanionHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Challenge Lab HUD"
        Width="440" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Border CornerRadius="16" BorderBrush="#552DE2E6" BorderThickness="1" Margin="8">
        <Border.Background>
            <SolidColorBrush Color="#E0121A2E"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CHALLENGE LAB" FontSize="10" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                    <TextBlock Text="{Binding PhaseLabel}" FontSize="16" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Style="{StaticResource GhostButton}" Padding="10,4"
                        Click="Close_Click" VerticalAlignment="Top"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="{Binding HudTip}" TextWrapping="Wrap" Margin="0,12,0,8"
                       Foreground="#FFFFB020" FontSize="13"/>

            <StackPanel Grid.Row="2">
                <!-- Live projected overall % (caption explains measuring vs assumed 100%) -->
                <Border Margin="0,0,0,10" Background="#330A2A20" CornerRadius="10" Padding="12,10"
                        BorderBrush="#66FFB020" BorderThickness="1"
                        Visibility="{Binding PreviewActive, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding PreviewHeading}" FontSize="10" FontWeight="Bold"
                                   Foreground="#FFFFB020"
                                   ToolTip="Live projection while airborne (unmeasured metrics = 100%). Switches to FINAL SCORE after settle."/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding PreviewScoreDisplay}" FontSize="40" FontWeight="Bold"
                                       Foreground="#FF2DE2E6"/>
                            <TextBlock Text="{Binding PreviewGrade}" FontSize="40" FontWeight="Bold"
                                       Margin="12,0,0,0" Foreground="#FFFFB020"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PreviewCaption}" FontSize="11" Foreground="#FF8B9BB8"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding LiveStats}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                           Foreground="#FF8B9BB8" TextWrapping="Wrap"/>

                <!-- Informational target only — not a live score -->
                <Border Margin="0,10,0,0" Background="#221A3A4A" CornerRadius="8" Padding="10,8"
                        BorderBrush="#442DE2E6" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="INFO · PERFECT LANDING SPEED" FontSize="9" FontWeight="Bold"
                                   Foreground="#FF2DE2E6"/>
                        <TextBlock Text="{Binding SpeedTargetInfo}" TextWrapping="Wrap" Margin="0,4,0,0"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   Foreground="#FFE8F8FF"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0" Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}"
                        Background="#22000000" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="LANDING SCORE" FontSize="10" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding LastScore.ScoreDisplay, Mode=OneWay}"
                                       FontSize="36" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                            <TextBlock Text="{Binding LastScore.Grade}" FontSize="36" FontWeight="Bold"
                                       Margin="12,0,0,0" Foreground="#FFFFB020"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                            <TextBlock Text="{Binding LastScore.Summary}" TextWrapping="Wrap" FontSize="12"
                                       FontFamily="Cascadia Mono, Consolas"
                                       Foreground="#FFE8EEF8" xml:space="preserve"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Bottom-left: resume after Start/Restart SET PAUSE hold -->
                <Button Grid.Column="0" Content="GO" Style="{StaticResource AmberButton}"
                        Command="{Binding GoCommand}"
                        ToolTip="Resume flight (SET PAUSE OFF). Use after Start/Restart instead of ESC → Resume."
                        FontWeight="Bold" FontSize="14" Padding="22,10" MinWidth="72"
                        HorizontalAlignment="Left"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Clean" Style="{StaticResource GhostButton}" Command="{Binding CleanMetricsCommand}"
                            ToolTip="Wipe landing metrics only (preview → 100%). No re-spawn."
                            Padding="12,8" Margin="0,0,8,0"/>
                    <Button Content="Restart" Style="{StaticResource GhostButton}" Command="{Binding RestartCommand}"
                            Padding="12,8" Margin="0,0,8,0"/>
                    <Button Content="Menu" Style="{StaticResource GhostButton}" Command="{Binding OpenMenuCommand}"
                            Padding="12,8" Margin="0,0,8,0"/>
                    <Button Content="Hide" Style="{StaticResource GhostButton}" Click="Close_Click" Padding="12,8"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
