<Window x:Class="ChallengeLab.App.Views.CompanionHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Challenge Lab HUD"
        Width="440" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Border CornerRadius="16" BorderBrush="#552DE2E6" BorderThickness="1" Margin="8">
        <Border.Background>
            <SolidColorBrush Color="#E0121A2E"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CHALLENGE LAB" FontSize="10" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                    <TextBlock Text="{Binding PhaseLabel}" FontSize="16" FontWeight="SemiBold" Foreground="#FFF2F6FF"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Style="{StaticResource GhostButton}" Padding="10,4"
                        Click="Close_Click" VerticalAlignment="Top"/>
            </Grid>

            <TextBlock Grid.Row="1" Text="{Binding HudTip}" TextWrapping="Wrap" Margin="0,12,0,8"
                       Foreground="#FFFFB020" FontSize="13"/>

            <StackPanel Grid.Row="2">
                <TextBlock Text="{Binding LiveStats}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                           Foreground="#FF8B9BB8" TextWrapping="Wrap"/>

                <Border Margin="0,14,0,0" Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}"
                        Background="#22000000" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="LANDING SCORE" FontSize="10" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding LastScore.ScoreDisplay, Mode=OneWay}"
                                       FontSize="36" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                            <TextBlock Text="{Binding LastScore.Grade}" FontSize="36" FontWeight="Bold"
                                       Margin="12,0,0,0" Foreground="#FFFFB020"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                            <TextBlock Text="{Binding LastScore.Summary}" TextWrapping="Wrap" FontSize="12"
                                       FontFamily="Cascadia Mono, Consolas"
                                       Foreground="#FFE8EEF8" xml:space="preserve"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Restart" Style="{StaticResource AmberButton}" Command="{Binding RestartCommand}"
                        Padding="12,8" Margin="0,0,8,0"/>
                <Button Content="Menu" Style="{StaticResource GhostButton}" Command="{Binding OpenMenuCommand}"
                        Padding="12,8" Margin="0,0,8,0"/>
                <Button Content="Hide" Style="{StaticResource GhostButton}" Click="Close_Click" Padding="12,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
