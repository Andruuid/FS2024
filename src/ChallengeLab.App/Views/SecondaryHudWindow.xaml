<Window x:Class="ChallengeLab.App.Views.SecondaryHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ChallengeLab.App.Controls"
        Title="Challenge Lab Flight Monitor"
        Width="420" Height="560"
        MinWidth="420" MinHeight="560"
        MaxWidth="420" MaxHeight="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border x:Name="MonitorChrome" Margin="8" Padding="16" CornerRadius="16"
            Background="#F0121A2E" BorderBrush="#662DE2E6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.58" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="DragHeader" Cursor="SizeAll" Background="#01000000"
                  MouseLeftButtonDown="DragHeader_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="FLIGHT MONITOR" FontSize="10" FontWeight="Bold" Foreground="#FF2DE2E6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="{Binding TargetLabel}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="  ·  " Foreground="#FF8B9BB8"/>
                        <TextBlock Text="{Binding PhaseLabel}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="#FFFFB020" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="{Binding MonitorStatus}" FontSize="10" Margin="0,2,0,0"
                               Foreground="#FF8B9BB8"/>
                </StackPanel>
                <Button x:Name="HideMonitorButton" Grid.Column="1" Content="Hide"
                        Style="{StaticResource GhostButton}" Padding="11,6"
                        Click="HideMonitor_Click" VerticalAlignment="Top"/>
            </Grid>

            <Border Grid.Row="1" Margin="0,12,0,10" Padding="12,10" CornerRadius="10"
                    Background="#33102535" BorderBrush="#554A90A4" BorderThickness="1">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="TOUCHDOWN PROGRESS" FontSize="9" FontWeight="Bold"
                                       Foreground="#FF8B9BB8"/>
                            <TextBlock Text="{Binding DistanceDisplay}" FontSize="10" Margin="0,2,0,0"
                                       FontFamily="Cascadia Mono, Consolas" Foreground="#FFC5D0E6"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="EST. TOUCHDOWN" FontSize="9" FontWeight="Bold"
                                       Foreground="#FF8B9BB8" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="EtaText" Text="{Binding EtaDisplay}" FontSize="24" FontWeight="Bold"
                                       FontFamily="Cascadia Mono, Consolas" Foreground="#FFFFB020"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Grid Height="42" Margin="0,5,0,0" ClipToBounds="True">
                        <Path Data="M 4,31 L 324,31 M 324,31 L 350,31" Stroke="#447AFFFF"
                              StrokeThickness="2" StrokeDashArray="4,4"/>
                        <Path Data="M 326,30 L 362,30 L 362,35 L 326,35 Z"
                              Fill="#668B9BB8"/>
                        <Path x:Name="ProgressAirplane"
                              Data="M 0,19 L 5,18.5 L 1,11 L 5.5,11 L 12.5,17 L 28.5,17 L 17,0 L 23,0 L 42,17 L 54,17 C 60,17 64,18 64,20 C 64,22 60,23 54,23 L 42,23 L 23,40 L 17,40 L 28.5,23 L 12.5,23 L 5.5,29 L 1,29 L 5,21.5 L 0,21 Z"
                              Fill="#FF2DE2E6" Width="64" Height="40" Stretch="Fill"
                              VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,1,0,0">
                            <Path.RenderTransform>
                                <TranslateTransform X="{Binding AirplaneOffset, Mode=OneWay}"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>
                    <Grid Margin="0,2,0,0">
                        <ProgressBar x:Name="ApproachProgressBar" Minimum="0" Maximum="100" Height="5"
                                     Value="{Binding ProgressPercent, Mode=OneWay, TargetNullValue=0, FallbackValue=0}"/>
                        <TextBlock Text="{Binding ProgressDisplay}" FontSize="10" FontWeight="Bold"
                                   Foreground="#FFF2F6FF" HorizontalAlignment="Center" Margin="0,7,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="AirspeedCard" Grid.Column="0" Margin="0,0,5,0" Padding="8,9"
                        CornerRadius="10" Background="#441A2540"
                        BorderBrush="{Binding AirspeedBrush, Mode=OneWay}" BorderThickness="2">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="IAS" FontSize="9" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                        <TextBlock Text="{Binding AirspeedDisplay}" FontSize="24" FontWeight="Bold"
                                   FontFamily="Cascadia Mono, Consolas" Foreground="{Binding AirspeedBrush, Mode=OneWay}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AirspeedDetail}" FontSize="8" TextWrapping="Wrap"
                                   TextAlignment="Center" Foreground="#FFC5D0E6"/>
                    </StackPanel>
                </Border>

                <Border x:Name="GlideslopeCard" Grid.Column="1" Margin="3,0" Padding="8,9"
                        CornerRadius="10" Background="#441A2540"
                        BorderBrush="{Binding GlideslopeBrush, Mode=OneWay}" BorderThickness="2">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="GLIDESLOPE" FontSize="9" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                        <TextBlock Text="{Binding GlideslopeDisplay}" FontSize="24" FontWeight="Bold"
                                   FontFamily="Cascadia Mono, Consolas" Foreground="{Binding GlideslopeBrush, Mode=OneWay}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding GlideslopeDetail}" FontSize="8" TextWrapping="Wrap"
                                   TextAlignment="Center" Foreground="#FFC5D0E6"/>
                    </StackPanel>
                </Border>

                <Border x:Name="VerticalSpeedCard" Grid.Column="2" Margin="5,0,0,0" Padding="8,9"
                        CornerRadius="10" Background="#441A2540"
                        BorderBrush="{Binding VerticalSpeedBrush, Mode=OneWay}" BorderThickness="2">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="VERTICAL SPEED" FontSize="9" FontWeight="Bold" Foreground="#FF8B9BB8"/>
                        <TextBlock Text="{Binding VerticalSpeedDisplay}" FontSize="19" FontWeight="Bold"
                                   FontFamily="Cascadia Mono, Consolas" Foreground="{Binding VerticalSpeedBrush, Mode=OneWay}"
                                   HorizontalAlignment="Center" Margin="0,3,0,2"/>
                        <TextBlock Text="{Binding VerticalSpeedDetail}" FontSize="8" TextWrapping="Wrap"
                                   TextAlignment="Center" Foreground="#FFC5D0E6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Padding="12,10" CornerRadius="10" Background="#441A2540"
                    BorderBrush="#334A90A4" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PROJECTED SCORE %" FontSize="10" FontWeight="Bold"
                                   Foreground="#FF2DE2E6"/>
                        <TextBlock Grid.Column="1" Text="TIME →" FontSize="9" Foreground="#FF8B9BB8"/>
                    </Grid>
                    <controls:LandingScoreGraph x:Name="ScoreGraph" Grid.Row="1" MinHeight="150"
                                                Points="{Binding GraphPoints, Mode=OneWay}"
                                                HorizonSeconds="{Binding GraphHorizonSeconds, Mode=OneWay}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
