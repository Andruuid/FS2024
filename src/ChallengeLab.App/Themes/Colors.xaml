<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BgDeep">#FF0B1020</Color>
    <Color x:Key="BgPanel">#FF121A2E</Color>
    <Color x:Key="BgCard">#FF1A2540</Color>
    <Color x:Key="BgCardHover">#FF223054</Color>
    <Color x:Key="AccentCyan">#FF2DE2E6</Color>
    <Color x:Key="AccentAmber">#FFFFB020</Color>
    <Color x:Key="AccentRed">#FFFF4D6A</Color>
    <Color x:Key="AccentGreen">#FF3DDC97</Color>
    <Color x:Key="TextPrimary">#FFF2F6FF</Color>
    <Color x:Key="TextMuted">#FF8B9BB8</Color>
    <Color x:Key="BorderSubtle">#33FFFFFF</Color>

    <SolidColorBrush x:Key="BrushBgDeep" Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BrushBgPanel" Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BrushBgCardHover" Color="{StaticResource BgCardHover}"/>
    <SolidColorBrush x:Key="BrushAccentCyan" Color="{StaticResource AccentCyan}"/>
    <SolidColorBrush x:Key="BrushAccentAmber" Color="{StaticResource AccentAmber}"/>
    <SolidColorBrush x:Key="BrushAccentRed" Color="{StaticResource AccentRed}"/>
    <SolidColorBrush x:Key="BrushAccentGreen" Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource BorderSubtle}"/>
</ResourceDictionary>
