{
  "id": "hardcore-crosswind-landing",
  "title": "Hardcore Crosswind Landing",
  "description": "Legacy flat criteria list. Prefer landing-evaluation-key.json for phase weights (Approach 25% / Touchdown 70% / Rollout 5%). Peak G removed.",
  "settledGroundSpeedKts": 50,
  "settledHoldSeconds": 1.0,
  "flareAglFeet": 50,
  "groundTrackWindowBeforeSeconds": 3,
  "groundTrackWindowAfterSeconds": 3,
  "postTouchdownAlignmentDelaySeconds": 2,
  "defaultVappKts": 143,
  "vappToTouchdownOffsetKts": 5,
  "vs0ToVappFactor": 1.3,
  "gearUpScoreMultiplier": 0.1,
  "criteria": [
    {
      "id": "touchdown_vs",
      "displayName": "Touchdown firmness",
      "weight": 1.6,
      "metric": "touchdownVerticalSpeedFpm",
      "evaluator": "piecewise",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "fpm",
      "note": "A330-style: ideal ~-150 fpm (−100…−180). Firm is good; ultra-soft float and hard landings are penalized.",
      "points": [
        { "v": -600, "s": 0.00 },
        { "v": -500, "s": 0.10 },
        { "v": -400, "s": 0.40 },
        { "v": -320, "s": 0.70 },
        { "v": -250, "s": 0.90 },
        { "v": -180, "s": 1.00 },
        { "v": -100, "s": 1.00 },
        { "v":  -60, "s": 0.90 },
        { "v":  -20, "s": 0.35 },
        { "v":    0, "s": 0.15 },
        { "v":   50, "s": 0.00 }
      ]
    },
    {
      "id": "centerline",
      "displayName": "Centerline deviation",
      "weight": 1.4,
      "metric": "centerlineDeviationM",
      "evaluator": "centerline",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "m",
      "note": "Absolute lateral offset at main-gear touchdown only — not crab/heading.",
      "params": {
        "tolerance": 3,
        "zeroAt": 15,
        "exponent": 1.5,
        "easyTolerance": 4,
        "easyZeroAt": 18,
        "easyExponent": 1.7,
        "strictTolerance": 1.5,
        "strictZeroAt": 10,
        "strictExponent": 1.3
      }
    },
    {
      "id": "alignment",
      "displayName": "Runway heading alignment",
      "weight": 1.1,
      "metric": "alignmentDeg",
      "evaluator": "target",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "deg",
      "note": "Fuselage heading vs runway course at touchdown (crab/drift). Separate from lateral centerline position.",
      "params": {
        "ideal": 0,
        "tolerance": 2,
        "maxError": 12
      }
    },
    {
      "id": "airspeed",
      "displayName": "Touchdown IAS vs target",
      "weight": 1.3,
      "metric": "touchdownIasErrorKts",
      "evaluator": "piecewise",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "kts",
      "note": "Scored vs target TD IAS = VAPP − 5 kt (not a fixed number). Ideal: target…target−5. Slightly fast still ok; large errors penalized.",
      "points": [
        { "v": -30, "s": 0.10 },
        { "v": -15, "s": 0.60 },
        { "v": -10, "s": 0.90 },
        { "v":  -5, "s": 1.00 },
        { "v":   0, "s": 1.00 },
        { "v":   5, "s": 0.95 },
        { "v":  10, "s": 0.75 },
        { "v":  15, "s": 0.60 },
        { "v":  25, "s": 0.20 },
        { "v":  35, "s": 0.00 }
      ]
    },
    {
      "id": "excess_speed",
      "displayName": "Excess speed over VAPP",
      "weight": 0.9,
      "metric": "excessSpeedOverVappKts",
      "evaluator": "piecewise",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "kts",
      "note": "Separate float/energy penalty: smooth at 155 kt can still mean a long landing. Prefer not above VAPP at touchdown.",
      "points": [
        { "v":  0, "s": 1.00 },
        { "v":  3, "s": 0.95 },
        { "v":  5, "s": 0.85 },
        { "v": 10, "s": 0.55 },
        { "v": 15, "s": 0.30 },
        { "v": 20, "s": 0.15 },
        { "v": 30, "s": 0.00 }
      ]
    },
    {
      "id": "bank",
      "displayName": "Bank at touchdown",
      "weight": 1.2,
      "metric": "bankAtTouchdownDeg",
      "evaluator": "target",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "deg",
      "note": "Keep wings level to protect pods in crosswind.",
      "params": {
        "ideal": 0,
        "tolerance": 1.5,
        "maxError": 8
      }
    },
    {
      "id": "gear",
      "displayName": "Gear (safety gate)",
      "weight": 0,
      "metric": "gearDown",
      "evaluator": "boolean",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "note": "Safety gate only: gear-down gives no bonus. Gear-up applies ~90% overall score cut unless the challenge sets requireGearDown=false (water/belly).",
      "params": {
        "expected": 1,
        "failScore": 0
      }
    },
    {
      "id": "flaps",
      "displayName": "Flaps setting",
      "weight": 0.7,
      "metric": "flapsIndex",
      "evaluator": "range",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "index",
      "note": "Flaps handle should be in the landing range for this challenge (typically full/approach config).",
      "params": {
        "min": 3,
        "max": 5,
        "zeroBelow": 1,
        "zeroAbove": 6
      }
    },
    {
      "id": "approach_path",
      "displayName": "Approach path quality",
      "weight": 0.9,
      "metric": "approachPathRms",
      "evaluator": "target",
      "sampleAt": "approach",
      "levels": ["strict"],
      "unit": "ft RMS",
      "note": "Strict only — how steadily you held the final approach path (altitude vs an ideal 3° profile).",
      "params": {
        "ideal": 0,
        "tolerance": 80,
        "maxError": 400
      }
    },
    {
      "id": "ground_track",
      "displayName": "Ground track along runway",
      "weight": 1.1,
      "metric": "groundTrackErrorMeanDeg",
      "evaluator": "target",
      "sampleAt": "touchdown",
      "levels": ["easy", "strict"],
      "unit": "deg",
      "note": "Mean |ground-track − runway heading| over 3 s before to 3 s after touchdown. CG motion, not crab.",
      "params": {
        "ideal": 0,
        "tolerance": 2,
        "maxError": 12
      }
    },
    {
      "id": "post_td_alignment",
      "displayName": "Rollout heading alignment",
      "weight": 1.2,
      "metric": "postTouchdownAlignmentMeanDeg",
      "evaluator": "target",
      "sampleAt": "rollout",
      "levels": ["easy", "strict"],
      "unit": "deg",
      "note": "From 2 s after touchdown until ~50 kt: fuselage heading vs runway. Should be de-crabbed and held with rudder.",
      "params": {
        "ideal": 0,
        "tolerance": 2,
        "maxError": 12
      }
    },
    {
      "id": "rollout_path",
      "displayName": "Rollout centerline path",
      "weight": 1.2,
      "metric": "rolloutLateralMeanM",
      "evaluator": "target",
      "sampleAt": "rollout",
      "levels": ["easy", "strict"],
      "unit": "m",
      "note": "Distance-weighted mean |offset| after touchdown: (∫|d| ds)/S. How close the rundown stays to centerline.",
      "params": {
        "ideal": 0,
        "tolerance": 3,
        "maxError": 18
      }
    },
    {
      "id": "rollout_weave",
      "displayName": "Rollout weave (S-turns)",
      "weight": 1.3,
      "metric": "rolloutWeaveIndex",
      "evaluator": "target",
      "sampleAt": "rollout",
      "levels": ["easy", "strict"],
      "unit": "m/m",
      "note": "Σ|Δd|/S after touchdown. Steady rundown ≈ 0; left-right steering oscillates and scores worse.",
      "params": {
        "ideal": 0,
        "tolerance": 0.02,
        "maxError": 0.25
      }
    },
    {
      "id": "max_centerline",
      "displayName": "Max lateral deviation (rollout)",
      "weight": 0.7,
      "metric": "rolloutLateralPeakM",
      "evaluator": "target",
      "sampleAt": "rollout",
      "levels": ["strict"],
      "unit": "m",
      "note": "Peak |centerline offset| after touchdown.",
      "params": {
        "ideal": 0,
        "tolerance": 6,
        "maxError": 30
      }
    }
  ]
}
