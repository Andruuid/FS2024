{
  "id": "free-flight-evaluation-key",
  "version": 4,
  "description": "Aircraft-generic free-flight landing score. Initial impact, flare/float, and post-contact stability are evaluated separately; flap index is not gated.",
  "formula": "phase = sum(metricScore * importancePercent / 100); final = sum(phaseScore * phaseWeightPercent / 100); apply the adaptive gear multiplier last only when required",
  "settle": {
    "groundSpeedKts": 50,
    "holdSeconds": 1.0
  },
  "timing": {
    "groundTrackWindowBeforeSeconds": 3,
    "groundTrackWindowAfterSeconds": 3,
    "postTouchdownAlignmentDelaySeconds": 2,
    "flareAglFeet": 50,
    "postArmIgnoreSeconds": 4,
    "requireAirborneBeforeTouchdown": true,
    "minAirborneAglFeet": 80,
    "minAirborneSamples": 8,
    "approachPathMinDistNm": 0.2,
    "approachPathMaxDistNm": 4.5,
    "impactPreWindowSeconds": 0.25,
    "impactWindowSeconds": 0.75,
    "impactFilterCutoffHz": 10.0,
    "impactPeakQuantile": 0.99,
    "minImpactSamples": 8,
    "bounceMinAirborneSeconds": 0.08,
    "bounceWindowSeconds": 3.0
  },
  "contactMapping": {
    "leftMainGearIndex": 1,
    "rightMainGearIndex": 2,
    "noseGearIndex": 0
  },
  "speedTarget": {
    "defaultVappKts": 70,
    "touchdownOffsetKts": 5,
    "vs0Factor": 1.3
  },
  "gates": {
    "gear": {
      "multiplierOnFail": 0.1,
      "penaltyDescription": "For retractable wheeled aircraft landing on land, gear up multiplies the complete ranked score by 0.1. Fixed gear and water-runway landings do not use this gate."
    }
  },
  "phases": [
    {
      "id": "touchdown",
      "displayName": "Touchdown",
      "weightPercent": 70,
      "note": "Touchdown technique and aircraft state. Ground track covers three seconds before through three seconds after touchdown.",
      "metrics": [
        {
          "id": "touchdown_impact",
          "displayName": "Touchdown impact",
          "importancePercent": 55,
          "unit": "%",
          "evaluator": "landingImpact",
          "note": "Initial main-gear impact only. Combines touchdown vertical speed and robust filtered peak G; later impacts are excluded.",
          "params": { "verticalSpeedWeight": 0.40, "peakGWeight": 0.60 },
          "curves": {
            "verticalSpeed": [
              { "v": -2000, "s": 0 }, { "v": -1200, "s": 10 }, { "v": -800, "s": 40 },
              { "v": -600, "s": 70 }, { "v": -500, "s": 75 }, { "v": -400, "s": 80 },
              { "v": -320, "s": 82 }, { "v": -250, "s": 90 }, { "v": -180, "s": 95 },
              { "v": -100, "s": 100 }, { "v": -60, "s": 95 }, { "v": -20, "s": 90 },
              { "v": 0, "s": 85 }, { "v": 50, "s": 50 }
            ],
            "peakG": [
              { "v": 0.85, "s": 75 }, { "v": 1.00, "s": 90 }, { "v": 1.10, "s": 97 },
              { "v": 1.15, "s": 100 }, { "v": 1.30, "s": 100 }, { "v": 1.40, "s": 92 },
              { "v": 1.55, "s": 70 }, { "v": 1.70, "s": 40 }, { "v": 1.90, "s": 10 },
              { "v": 2.10, "s": 0 }
            ]
          }
        },
        {
          "id": "flare_efficiency",
          "displayName": "Flare and float efficiency",
          "importancePercent": 10,
          "unit": "%",
          "evaluator": "flareEfficiency",
          "params": {
            "entryVerticalSpeedFpm": -80, "minSustainSeconds": 0.15,
            "distanceWeight": 0.70, "timeWeight": 0.10, "positiveVerticalSpeedWeight": 0.20
          },
          "curves": {
            "distance": [
              { "v": 0, "s": 100 }, { "v": 60, "s": 100 }, { "v": 120, "s": 95 },
              { "v": 200, "s": 75 }, { "v": 350, "s": 35 }, { "v": 500, "s": 0 }
            ],
            "time": [
              { "v": 0.0, "s": 100 }, { "v": 1.0, "s": 100 }, { "v": 2.0, "s": 85 },
              { "v": 3.5, "s": 50 }, { "v": 6.0, "s": 0 }
            ],
            "positiveVerticalSpeedSeconds": [
              { "v": 0.00, "s": 100 }, { "v": 0.15, "s": 90 }, { "v": 0.40, "s": 60 },
              { "v": 0.80, "s": 20 }, { "v": 1.20, "s": 0 }
            ]
          }
        },
        {
          "id": "contact_stability",
          "displayName": "Contact stability",
          "importancePercent": 10,
          "unit": "%",
          "evaluator": "contactStability",
          "params": {
            "countWeight": 0.45, "maxAirborneDurationWeight": 0.20,
            "worstSecondaryImpactWeight": 0.35
          },
          "curves": {
            "count": [
              { "v": 0, "s": 100 }, { "v": 1, "s": 65 }, { "v": 2, "s": 25 }, { "v": 3, "s": 0 }
            ],
            "maxAirborneDuration": [
              { "v": 0.00, "s": 100 }, { "v": 0.08, "s": 95 }, { "v": 0.25, "s": 80 },
              { "v": 0.50, "s": 55 }, { "v": 1.00, "s": 20 }, { "v": 1.50, "s": 0 }
            ]
          }
        },
        {
          "id": "airspeed",
          "displayName": "IAS versus touchdown target",
          "importancePercent": 13,
          "unit": "kts",
          "evaluator": "piecewise",
          "metric": "touchdownIasErrorKts",
          "note": "Target-accuracy metric. The target is VAPP minus 5 kt by default. Being fast is already punished more heavily than being slow.",
          "points": [
            { "v": -30, "s": 70 },
            { "v": -15, "s": 80 },
            { "v": -10, "s": 90 },
            { "v": -5, "s": 100 },
            { "v": 0, "s": 100 },
            { "v": 5, "s": 95 },
            { "v": 10, "s": 75 },
            { "v": 15, "s": 60 },
            { "v": 25, "s": 20 },
            { "v": 35, "s": 10 }
          ]
        },
        {
          "id": "centerline",
          "displayName": "Centerline offset",
          "importancePercent": 7,
          "unit": "m",
          "evaluator": "centerline",
          "metric": "centerlineDeviationM",
          "note": "Touchdown lateral offset. Full score within ~half a strip width; zero near runway edge on a typical narrow runway.",
          "params": {
            "tolerance": 3,
            "zeroAt": 22,
            "exponent": 1.2
          }
        },
        {
          "id": "ground_track",
          "displayName": "Ground track (CG path)",
          "importancePercent": 3,
          "unit": "deg",
          "evaluator": "target",
          "metric": "groundTrackErrorMeanDeg",
          "sampleAt": "touchdownWindow",
          "note": "Mean CG ground-track error across the touchdown window, not fuselage crab angle.",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "bank",
          "displayName": "Bank at touchdown",
          "importancePercent": 2,
          "unit": "deg",
          "evaluator": "target",
          "metric": "bankAtTouchdownDeg",
          "params": { "ideal": 0, "tolerance": 1.5, "maxError": 8 }
        }
      ]
    },
    {
      "id": "approach",
      "displayName": "Approach",
      "weightPercent": 25,
      "note": "Short final (≈0.2–4.5 NM): average 3° path match, vertical steadiness, and lateral steadiness share the phase equally.",
      "metrics": [
        {
          "id": "approach_glideslope",
          "displayName": "Average glideslope match",
          "importancePercent": 33.34,
          "unit": "ft",
          "evaluator": "target",
          "metric": "approachGlideslopeMeanAbsFt",
          "note": "Time-weighted mean absolute altitude error vs the runway glideslope path (default 3°; free-flight may use VASI). Aim point is 1,200 ft past threshold. Samples at/below flare AGL are excluded. High and low deviations cannot cancel.",
          "params": { "ideal": 0, "tolerance": 40, "maxError": 350 }
        },
        {
          "id": "approach_vertical_steady",
          "displayName": "Vertical steadiness",
          "importancePercent": 33.33,
          "unit": "ft/s",
          "evaluator": "target",
          "metric": "approachVerticalVariationFtPerSec",
          "note": "Total vertical path pumping: Σ|Δe| / T. Steady path scores high; large corrections and oscillations score low.",
          "params": { "ideal": 0, "tolerance": 3, "maxError": 25 }
        },
        {
          "id": "approach_lateral_steady",
          "displayName": "Lateral steadiness",
          "importancePercent": 33.33,
          "unit": "m/m",
          "evaluator": "target",
          "metric": "approachLateralWeaveIndex",
          "note": "Total lateral path change: Σ|Δd| / ground distance. Straight track scores high; big corrections and S-turns score low.",
          "params": { "ideal": 0, "tolerance": 0.02, "maxError": 0.20 }
        }
      ]
    },
    {
      "id": "rollout",
      "displayName": "Rollout",
      "weightPercent": 5,
      "note": "Heading, centerline path, weave, and peak lateral deviation share the phase equally.",
      "metrics": [
        {
          "id": "post_td_alignment",
          "displayName": "Rollout heading alignment",
          "importancePercent": 25,
          "unit": "deg",
          "evaluator": "target",
          "metric": "postTouchdownAlignmentMeanDeg",
          "note": "Mean fuselage heading error after the configured de-crab delay until settling.",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "rollout_path",
          "displayName": "Rollout centerline path",
          "importancePercent": 25,
          "unit": "m",
          "evaluator": "target",
          "metric": "rolloutLateralMeanM",
          "note": "Distance-weighted mean |offset| on rollout. Full score within a few metres; zero near a typical runway edge (~half-width).",
          "params": { "ideal": 0, "tolerance": 5, "maxError": 50 }
        },
        {
          "id": "rollout_weave",
          "displayName": "Rollout weave (S-turns)",
          "importancePercent": 25,
          "unit": "m/m",
          "evaluator": "target",
          "metric": "rolloutWeaveIndex",
          "params": { "ideal": 0, "tolerance": 0.02, "maxError": 0.25 }
        },
        {
          "id": "max_centerline",
          "displayName": "Max lateral deviation (rollout)",
          "importancePercent": 25,
          "unit": "m",
          "evaluator": "target",
          "metric": "rolloutLateralPeakM",
          "params": { "ideal": 0, "tolerance": 10, "maxError": 45 }
        }
      ]
    }
  ]
}
