{
  "id": "landing-evaluation-key",
  "version": 6,
  "description": "Single authoritative landing score. Every metric scores 0-100%; phases and metrics use literal percentage weights; gear and flaps are safety gates and never award points.",
  "formula": "phase = sum(metricScore * importancePercent / 100); final = sum(phaseScore * phaseWeightPercent / 100); apply gear/flaps multipliers last when required",
  "settle": {
    "groundSpeedKts": 50,
    "holdSeconds": 1.0
  },
  "timing": {
    "groundTrackWindowBeforeSeconds": 3,
    "groundTrackWindowAfterSeconds": 3,
    "postTouchdownAlignmentDelaySeconds": 2,
    "flareAglFeet": 50,
    "postArmIgnoreSeconds": 4,
    "requireAirborneBeforeTouchdown": true,
    "minAirborneAglFeet": 80,
    "minAirborneSamples": 8,
    "approachPathMinDistNm": 0.2,
    "approachPathMaxDistNm": 3.0
  },
  "speedTarget": {
    "defaultVappKts": 143,
    "touchdownOffsetKts": 5,
    "vs0Factor": 1.3
  },
  "gates": {
    "gear": {
      "multiplierOnFail": 0.1,
      "penaltyDescription": "If gear is required and up, multiply the complete ranked score by 0.1. Gear down is the required baseline and awards no points."
    },
    "flaps": {
      "minIndex": 2,
      "maxIndex": 5,
      "multiplierOnFail": 0.5,
      "penaltyDescription": "If flaps are not set for landing (index below min / above max), multiply the complete ranked score by 0.5. Correct flaps award no points."
    }
  },
  "phases": [
    {
      "id": "touchdown",
      "displayName": "Touchdown",
      "weightPercent": 70,
      "note": "Touchdown technique and aircraft state. Ground track covers three seconds before through three seconds after touchdown.",
      "metrics": [
        {
          "id": "touchdown_vs",
          "displayName": "Vertical speed (firmness)",
          "importancePercent": 75,
          "unit": "fpm",
          "evaluator": "piecewise",
          "metric": "touchdownVerticalSpeedFpm",
          "note": "Vertical speed at main-gear touchdown. A controlled firm plant is preferred over a float or hard impact. Hard impacts below -600 fpm score down to 0% by -2000 fpm.",
          "points": [
            { "v": -2000, "s": 0 },
            { "v": -1200, "s": 10 },
            { "v": -800, "s": 40 },
            { "v": -600, "s": 70 },
            { "v": -500, "s": 75 },
            { "v": -400, "s": 80 },
            { "v": -320, "s": 82 },
            { "v": -250, "s": 90 },
            { "v": -180, "s": 95 },
            { "v": -100, "s": 100 },
            { "v": -60, "s": 95 },
            { "v": -20, "s": 90 },
            { "v": 0, "s": 85 },
            { "v": 50, "s": 50 }
          ]
        },
        {
          "id": "airspeed",
          "displayName": "IAS versus touchdown target",
          "importancePercent": 10,
          "unit": "kts",
          "evaluator": "piecewise",
          "metric": "touchdownIasErrorKts",
          "note": "Target-accuracy metric worth at most 7.0 overall points. The target is VAPP minus 5 kt by default.",
          "points": [
            { "v": -30, "s": 70 },
            { "v": -15, "s": 80 },
            { "v": -10, "s": 90 },
            { "v": -5, "s": 100 },
            { "v": 0, "s": 100 },
            { "v": 5, "s": 95 },
            { "v": 10, "s": 75 },
            { "v": 15, "s": 60 },
            { "v": 25, "s": 20 },
            { "v": 35, "s": 10 }
          ]
        },
        {
          "id": "centerline",
          "displayName": "Centerline offset",
          "importancePercent": 5,
          "unit": "m",
          "evaluator": "centerline",
          "metric": "centerlineDeviationM",
          "note": "Touchdown lateral offset. Full score within ~half a strip width; zero near runway edge on a typical narrow runway.",
          "params": {
            "tolerance": 3,
            "zeroAt": 22,
            "exponent": 1.2
          }
        },
        {
          "id": "ground_track",
          "displayName": "Ground track (CG path)",
          "importancePercent": 3,
          "unit": "deg",
          "evaluator": "target",
          "metric": "groundTrackErrorMeanDeg",
          "sampleAt": "touchdownWindow",
          "note": "Mean CG ground-track error across the touchdown window, not fuselage crab angle.",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "excess_speed",
          "displayName": "Excess speed over VAPP",
          "importancePercent": 3,
          "unit": "kts",
          "evaluator": "piecewise",
          "metric": "excessSpeedOverVappKts",
          "note": "Excess-energy metric worth at most 2.1 overall points. It penalizes float risk separately from target accuracy.",
          "points": [
            { "v": 0, "s": 100 },
            { "v": 3, "s": 95 },
            { "v": 5, "s": 85 },
            { "v": 10, "s": 55 },
            { "v": 15, "s": 30 },
            { "v": 20, "s": 15 },
            { "v": 30, "s": 0 }
          ]
        },
        {
          "id": "bank",
          "displayName": "Bank at touchdown",
          "importancePercent": 2,
          "unit": "deg",
          "evaluator": "target",
          "metric": "bankAtTouchdownDeg",
          "params": { "ideal": 0, "tolerance": 1.5, "maxError": 8 }
        },
        {
          "id": "alignment",
          "displayName": "Heading versus runway",
          "importancePercent": 2,
          "unit": "deg",
          "evaluator": "target",
          "metric": "alignmentDeg",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        }
      ]
    },
    {
      "id": "approach",
      "displayName": "Approach",
      "weightPercent": 25,
      "note": "Short final (≈0.2–3.0 NM): average 3° path match, vertical steadiness, and lateral steadiness share the phase equally.",
      "metrics": [
        {
          "id": "approach_glideslope",
          "displayName": "Average glideslope match",
          "importancePercent": 33.34,
          "unit": "ft",
          "evaluator": "target",
          "metric": "approachGlideslopeMeanAbsFt",
          "note": "Time-weighted mean absolute altitude error vs the nominal 3° path: ∫|e(t)| dt / T. High and low deviations cannot cancel.",
          "params": { "ideal": 0, "tolerance": 40, "maxError": 350 }
        },
        {
          "id": "approach_vertical_steady",
          "displayName": "Vertical steadiness",
          "importancePercent": 33.33,
          "unit": "ft/s",
          "evaluator": "target",
          "metric": "approachVerticalVariationFtPerSec",
          "note": "Reversal-only vertical pumping: (Σ|Δe| − |e_last − e_first|) / T, summed per continuous segment. A smooth one-way capture is not penalized.",
          "params": { "ideal": 0, "tolerance": 3, "maxError": 25 }
        },
        {
          "id": "approach_lateral_steady",
          "displayName": "Lateral steadiness",
          "importancePercent": 33.33,
          "unit": "m/m",
          "evaluator": "target",
          "metric": "approachLateralWeaveIndex",
          "note": "Reversal-only lateral weave: (Σ|Δd| − |d_last − d_first|) / ground distance, summed per continuous segment. A smooth intercept is not penalized; S-turns are.",
          "params": { "ideal": 0, "tolerance": 0.02, "maxError": 0.20 }
        }
      ]
    },
    {
      "id": "rollout",
      "displayName": "Rollout",
      "weightPercent": 5,
      "note": "Heading, centerline path, weave, and peak lateral deviation share the phase equally.",
      "metrics": [
        {
          "id": "post_td_alignment",
          "displayName": "Rollout heading alignment",
          "importancePercent": 25,
          "unit": "deg",
          "evaluator": "target",
          "metric": "postTouchdownAlignmentMeanDeg",
          "note": "Mean fuselage heading error after the configured de-crab delay until settling.",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "rollout_path",
          "displayName": "Rollout centerline path",
          "importancePercent": 25,
          "unit": "m",
          "evaluator": "target",
          "metric": "rolloutLateralMeanM",
          "note": "Distance-weighted mean |offset| on rollout. Full score within a few metres; zero near a typical runway edge (~half-width).",
          "params": { "ideal": 0, "tolerance": 5, "maxError": 50 }
        },
        {
          "id": "rollout_weave",
          "displayName": "Rollout weave (S-turns)",
          "importancePercent": 25,
          "unit": "m/m",
          "evaluator": "target",
          "metric": "rolloutWeaveIndex",
          "params": { "ideal": 0, "tolerance": 0.02, "maxError": 0.25 }
        },
        {
          "id": "max_centerline",
          "displayName": "Max lateral deviation (rollout)",
          "importancePercent": 25,
          "unit": "m",
          "evaluator": "target",
          "metric": "rolloutLateralPeakM",
          "params": { "ideal": 0, "tolerance": 10, "maxError": 45 }
        }
      ]
    }
  ]
}
