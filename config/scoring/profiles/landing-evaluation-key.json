{
  "id": "landing-evaluation-key",
  "version": 2,
  "description": "Single authoritative landing score. Every metric scores 0-100%; phases and metrics use literal percentage weights; gear is a safety gate and never awards points.",
  "formula": "phase = sum(metricScore * importancePercent / 100); final = sum(phaseScore * phaseWeightPercent / 100); apply gear multiplier last when required",
  "settle": {
    "groundSpeedKts": 50,
    "holdSeconds": 1.0
  },
  "timing": {
    "groundTrackWindowBeforeSeconds": 3,
    "groundTrackWindowAfterSeconds": 3,
    "postTouchdownAlignmentDelaySeconds": 2,
    "flareAglFeet": 50
  },
  "speedTarget": {
    "defaultVappKts": 143,
    "touchdownOffsetKts": 5,
    "vs0Factor": 1.3
  },
  "gates": {
    "gear": {
      "multiplierOnFail": 0.1,
      "penaltyDescription": "If gear is required and up, multiply the complete ranked score by 0.1. Gear down is the required baseline and awards no points."
    }
  },
  "phases": [
    {
      "id": "touchdown",
      "displayName": "Touchdown",
      "weightPercent": 70,
      "note": "Touchdown technique and aircraft state. Ground track covers three seconds before through three seconds after touchdown.",
      "metrics": [
        {
          "id": "touchdown_vs",
          "displayName": "Vertical speed (firmness)",
          "importancePercent": 75,
          "unit": "fpm",
          "evaluator": "piecewise",
          "metric": "touchdownVerticalSpeedFpm",
          "note": "Vertical speed at main-gear touchdown. A controlled firm plant is preferred over a float or hard impact.",
          "points": [
            { "v": -600, "s": 70 },
            { "v": -500, "s": 75 },
            { "v": -400, "s": 80 },
            { "v": -320, "s": 82 },
            { "v": -250, "s": 90 },
            { "v": -180, "s": 95 },
            { "v": -100, "s": 100 },
            { "v": -60, "s": 95 },
            { "v": -20, "s": 90 },
            { "v": 0, "s": 85 },
            { "v": 50, "s": 50 }
          ]
        },
        {
          "id": "airspeed",
          "displayName": "IAS versus touchdown target",
          "importancePercent": 10,
          "unit": "kts",
          "evaluator": "piecewise",
          "metric": "touchdownIasErrorKts",
          "note": "Target-accuracy metric worth at most 7.0 overall points. The target is VAPP minus 5 kt by default.",
          "points": [
            { "v": -30, "s": 70 },
            { "v": -15, "s": 80 },
            { "v": -10, "s": 90 },
            { "v": -5, "s": 100 },
            { "v": 0, "s": 100 },
            { "v": 5, "s": 95 },
            { "v": 10, "s": 75 },
            { "v": 15, "s": 60 },
            { "v": 25, "s": 20 },
            { "v": 35, "s": 10 }
          ]
        },
        {
          "id": "centerline",
          "displayName": "Centerline offset",
          "importancePercent": 5,
          "unit": "m",
          "evaluator": "centerline",
          "metric": "centerlineDeviationM",
          "params": {
            "tolerance": 1.5,
            "zeroAt": 10,
            "exponent": 1.3
          }
        },
        {
          "id": "ground_track",
          "displayName": "Ground track (CG path)",
          "importancePercent": 3,
          "unit": "deg",
          "evaluator": "target",
          "metric": "groundTrackErrorMeanDeg",
          "sampleAt": "touchdownWindow",
          "note": "Mean CG ground-track error across the touchdown window, not fuselage crab angle.",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "excess_speed",
          "displayName": "Excess speed over VAPP",
          "importancePercent": 3,
          "unit": "kts",
          "evaluator": "piecewise",
          "metric": "excessSpeedOverVappKts",
          "note": "Excess-energy metric worth at most 2.1 overall points. It penalizes float risk separately from target accuracy.",
          "points": [
            { "v": 0, "s": 100 },
            { "v": 3, "s": 95 },
            { "v": 5, "s": 85 },
            { "v": 10, "s": 55 },
            { "v": 15, "s": 30 },
            { "v": 20, "s": 15 },
            { "v": 30, "s": 0 }
          ]
        },
        {
          "id": "bank",
          "displayName": "Bank at touchdown",
          "importancePercent": 2,
          "unit": "deg",
          "evaluator": "target",
          "metric": "bankAtTouchdownDeg",
          "params": { "ideal": 0, "tolerance": 1.5, "maxError": 8 }
        },
        {
          "id": "alignment",
          "displayName": "Heading versus runway",
          "importancePercent": 1,
          "unit": "deg",
          "evaluator": "target",
          "metric": "alignmentDeg",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "flaps",
          "displayName": "Flaps setting",
          "importancePercent": 1,
          "unit": "index",
          "evaluator": "range",
          "metric": "flapsIndex",
          "params": { "min": 3, "max": 5, "zeroBelow": 1, "zeroAbove": 6 }
        }
      ]
    },
    {
      "id": "approach",
      "displayName": "Approach",
      "weightPercent": 25,
      "note": "Accuracy relative to the nominal three-degree approach path.",
      "metrics": [
        {
          "id": "approach_path",
          "displayName": "3° path accuracy",
          "importancePercent": 100,
          "unit": "ft RMS",
          "evaluator": "target",
          "metric": "approachPathRms",
          "params": { "ideal": 0, "tolerance": 80, "maxError": 400 }
        }
      ]
    },
    {
      "id": "rollout",
      "displayName": "Rollout",
      "weightPercent": 5,
      "note": "Heading, centerline path, weave, and peak lateral deviation share the phase equally.",
      "metrics": [
        {
          "id": "post_td_alignment",
          "displayName": "Rollout heading alignment",
          "importancePercent": 25,
          "unit": "deg",
          "evaluator": "target",
          "metric": "postTouchdownAlignmentMeanDeg",
          "note": "Mean fuselage heading error after the configured de-crab delay until settling.",
          "params": { "ideal": 0, "tolerance": 2, "maxError": 12 }
        },
        {
          "id": "rollout_path",
          "displayName": "Rollout centerline path",
          "importancePercent": 25,
          "unit": "m",
          "evaluator": "target",
          "metric": "rolloutLateralMeanM",
          "params": { "ideal": 0, "tolerance": 3, "maxError": 18 }
        },
        {
          "id": "rollout_weave",
          "displayName": "Rollout weave (S-turns)",
          "importancePercent": 25,
          "unit": "m/m",
          "evaluator": "target",
          "metric": "rolloutWeaveIndex",
          "params": { "ideal": 0, "tolerance": 0.02, "maxError": 0.25 }
        },
        {
          "id": "max_centerline",
          "displayName": "Max lateral deviation (rollout)",
          "importancePercent": 25,
          "unit": "m",
          "evaluator": "target",
          "metric": "rolloutLateralPeakM",
          "params": { "ideal": 0, "tolerance": 6, "maxError": 30 }
        }
      ]
    }
  ]
}
